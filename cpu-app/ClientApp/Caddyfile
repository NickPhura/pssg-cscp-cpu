# Required Environment Variables:
# - API_URL: The URL for the API (e.g., http://localhost:5000). Must not include a trailing slash.
{
	admin off
}

:2015 {
	log {
		output stdout
	}

	encode zstd gzip

	# Serve static content from the /site directory (defined in Dockerfile)
	root * /site

	file_server

	header {
		# Enable HTTP Strict Transport Security (HSTS) to force clients to always connect via HTTPS (do not use if only testing)
		Strict-Transport-Security "max-age=86400; includeSubDomains";
		# Enable cross-site filter (XSS) and tell browser to block detected attacks
		X-XSS-Protection "1; mode=block"
		# Prevent some browsers from MIME-sniffing a response away from the declared Content-Type
		X-Content-Type-Options "nosniff"
		# Disallow the site to be rendered within a frame (clickjacking protection)
		X-Frame-Options "DENY"
		# Set CSP
		# Content-Security-Policy " default-src 'self'; script-src 'self' https://apis.google.com https://maxcdn.bootstrapcdn.com https://cdnjs.cloudflare.com https://code.jquery.com https://stackpath.bootstrapcdn.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://use.fontawesome.com https://stackpath.bootstrapcdn.com https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://use.fontawesome.com https://fonts.gstatic.com; connect-src 'self' {$API_URL}; frame-src 'self' data:; object-src 'none'; form-action 'self'; frame-ancestors 'self'; block-all-mixed-content;"
		# Content-Security-Policy "default-src 'self'; base-uri 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' {$API_URL}; manifest-src 'self'; worker-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests; block-all-mixed-content;"
		# Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self'; script-src-attr 'unsafe-inline'; script-src-elem 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' {$API_URL}; frame-src 'self'; object-src 'none'; form-action 'self'; frame-ancestors 'self'; block-all-mixed-content;"
		Content-Security-Policy "default-src * data: blob: filesystem: 'unsafe-inline' 'unsafe-eval'";
		# Set referrer policy
		Referrer-Policy "same-origin"
	}

	respond /health 200

	# Handle API requests via Openshift route
	@api1 path /coastcontracts/api /coastcontracts/api/*
	handle @api1 {
		reverse_proxy {$API_URL}
	}

	# Handle API requests via [dev.|test.]justice.gov.bc.ca routes
	@api2 path /api /api/*
	handle @api2 {
		reverse_proxy {$API_URL} {
			header_up Host {upstream_hostport}
			header_up X-Forwarded-Host {host}
		}
	}

	# Handle APP requests via Openshift route
	handle_path /coastcontracts* {
		try_files {path} {path}/ /index.html
	}

	# Handle APP requests via [dev.|test.]justice.gov.bc.ca routes
	handle {
		try_files {path} {path}/ /index.html
	}
}
